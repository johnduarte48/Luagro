<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/light_gray">

    <!-- Ícono -->

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo_luagro"
        android:scaleType="fitCenter"/>

    <!-- Título -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/recuperar_contrase_a"
        android:textStyle="bold"
        android:textSize="28sp"
        android:textColor="@color/text_primary"
        android:layout_marginTop="24dp"/>

    <!-- Texto -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ingresa_tu_correo_electr_nico_para_recuperar_el_acceso"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"/>

    <!-- Input -->

    <EditText
        android:id="@+id/etRecoveryEmail"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="@string/correo_electr_nico"
        android:background="@drawable/input_background"
        android:padding="16dp"
        android:inputType="textEmailAddress"/>

    <!-- Botón -->

    <Button
        android:id="@+id/btnRecovery"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/enviar_enlace"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:background="@drawable/rounded_button"
        android:layout_marginTop="32dp"/>

</LinearLayout>